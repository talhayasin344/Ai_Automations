    {
      "parameters": {
        "jsCode": "const replyData = $('Extract Reply Info').first().json;\nconst leads = $input.all();\n\nconst matchedLead = leads.find(item => item.json.Email === replyData.senderEmail);\n\nif (!matchedLead) {\n  return [{ json: { found: false } }];\n}\n\nreturn [{\n  json: {\n    found: true,\n    name: matchedLead.json.Name,\n    company: matchedLead.json.Company,\n    business: matchedLead.json.Business,\n    issueorpitch: matchedLead.json[\"Issue or Pitch\"],\n    email: matchedLead.json.Email,\n    threadId: replyData.threadId,\n    messageId: replyData.messageId,\n    replyBody: replyData.replyBody,\n    subject: replyData.subject\n  }\n}];"
      },
