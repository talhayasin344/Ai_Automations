    {
      "parameters": {
        "jsCode": "const items = $input.all();\nconst results = [];\n\nfor (const item of items) {\n  let fromField = item.json.from || '';\n  \n  // Handle if from is an object or array\n  if (typeof fromField === 'object') {\n    fromField = fromField?.email || fromField?.value?.[0]?.address || JSON.stringify(fromField);\n  }\n  \n  // Now safely convert to string\n  fromField = String(fromField);\n  \n  const emailMatch = fromField.match(/<(.+?)>/);\n  const senderEmail = emailMatch ? emailMatch[1] : fromField.trim();\n  \n  results.push({\n    json: {\n      threadId: item.json.threadId,\n      messageId: item.json.id,\n      senderEmail: senderEmail.toLowerCase().trim(),\n      replyBody: item.json.text || item.json.snippet || '',\n      subject: item.json.subject || ''\n    }\n  });\n}\n\nreturn results;"
      },
